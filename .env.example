# Jewellery Store Frontend Environment Configuration

# API Configuration
VITE_API_URL=http://localhost:3000/api

# App Configuration
VITE_APP_NAME=Jewels
VITE_ENVIRONMENT=development

# Feature Flags
VITE_ENABLE_MOCK_DATA=true
VITE_ENABLE_ADMIN_FEATURES=true

# Analytics (optional)
